# Required: get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional model overrides (defaults shown)
# Coach = outer Socratic agent + inner evaluator (both run on Opus 4.7).
# Aux   = lightweight calls (titling, weakness summarization).
CLAUDE_COACH_MODEL=claude-opus-4-7
CLAUDE_AUX_MODEL=claude-haiku-4-5-20251001

# Server URLs (used by web container; defaults match docker-compose)
MCP_SERVER_URL=http://server:8000/mcp

# Dev backend (default: api). Set agent_sdk to route LLM calls through
# Claude Code subscription auth instead of metered API. Requires
# CLAUDE_CODE_OAUTH_TOKEN. See README.md "Dev backend setup".
CHAT_BACKEND=agent_sdk

# Output of `claude setup-token`. 1-year OAuth token bound to your
# Claude Code Team subscription. Required when CHAT_BACKEND=agent_sdk.
CLAUDE_CODE_OAUTH_TOKEN=oat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
