# Required: get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional model overrides (defaults shown)
# Coach = outer Socratic agent + inner evaluator (both run on Opus 4.7).
# Aux   = lightweight calls (titling, weakness summarization).
CLAUDE_COACH_MODEL=claude-opus-4-7
CLAUDE_AUX_MODEL=claude-haiku-4-5-20251001

# Server URLs (used by web container; defaults match docker-compose)
MCP_SERVER_URL=http://server:8000/mcp
